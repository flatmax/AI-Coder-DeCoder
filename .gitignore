# Python bytecode and build artefacts
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/

# AC-DC runtime state (per-repo working directory).
# Two entries intentional — `.ac-dc4/` is this reimplementation's
# working directory; `.ac-dc/` is the previous implementation's.
# During the transition both may coexist in a shared repository.
# See src/ac_dc/config.py:_AC_DC_DIR for the rename rationale.
.ac-dc4/
.ac-dc/

# Node / webapp build output
node_modules/
webapp/node_modules/
webapp/dist/

# Environments
.venv/
venv/
.env

# Logs
*.log

# uv lockfiles — deferred until uv workflow is chosen
uv.lock

# Editor / tooling scratch directories
.aicoder/
safeZone/
